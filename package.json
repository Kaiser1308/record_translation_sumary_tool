{
  "name": "speech-translator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:bug-analysis": "vitest src/hooks/*.bug-analysis.test.js",
