    "gitnexus:analyze": "bash ./scripts/gitnexus.sh analyze"
  },
  "dependencies": {
    "dompurify": "^3.4.1",
    "marked": "^12.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.3.0",
    "gitnexus": "^1.5.3",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "vite": "^5.4.0",
    "vitest": "^4.1.4"
  }
